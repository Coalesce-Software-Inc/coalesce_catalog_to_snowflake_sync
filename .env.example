# Coalesce Catalog to Snowflake Sync - Environment Configuration
# Copy this file to .env and fill in your actual values:  cp .env.example .env

# Your Coalesce Catalog API Token (REQUIRED)
# Get this from: https://app.us.castordoc.com/ -> Settings -> API Tokens
# GitHub Actions: Store as SECRET (Settings > Secrets > Actions)
COALESCE_API_TOKEN=your_api_token_here

# Deployment zone: US or EU (optional - defaults to US)
# GitHub Actions: Store as VARIABLE (Settings > Variables > Actions)
COALESCE_ZONE=US

# Slack Webhook URL for notifications (optional)
# GitHub Actions: Store as SECRET
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
